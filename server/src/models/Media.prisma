model Media {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String
  providerId  String
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
