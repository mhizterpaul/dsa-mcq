enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id                    String             @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  body                  String
  difficulty            Difficulty
  categoryId            String @db.ObjectId @db.ObjectId
  category              Category        @relation(fields: [categoryId], references: [id])
  tags                  TagOnQuestion[]
  tagsText              String          @default("")
  successRate           Float           @default(0)
  totalSubmissions      Int             @default(0)
  totalAccepted         Int             @default(0)
  companyTags           String          @default("")
  likes                 Int             @default(0)
  dislikes              Int             @default(0)
  hints                 String          @default("")
  similarQuestionIds    String          @default("")
  similarQuestionsText  String          @default("")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  quizQuestions       QuizQuestion[]
  userQuestionData    UserQuestionData[] 
  // ✅ New columns for MCQ options
  a                     String
  b                     String
  c                     String
  d                     String
  correct               String

  @@index([difficulty])
  @@index([categoryId])
}
